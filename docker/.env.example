# Copy to docker/.env before running: cp docker/.env.example docker/.env
#
# make docker-up LIVEKIT=local   # self-hosted LiveKit (default)
# make docker-up LIVEKIT=cloud   # LiveKit Cloud (set wss:// URL below)
# make docker-up LIVEKIT=off     # frontend + backend only (no agent, no LiveKit)

TZ=Asia/Kolkata

# Browser-reachable URLs (used at frontend build time and returned to clients)
# Local:
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
# Production (after: sudo bash nginx/scripts/enable-ssl.sh):
# NEXT_PUBLIC_API_URL=https://mykare.backend.geeekgod.in
# BACKEND_URL=https://mykare.backend.geeekgod.in
FRONTEND_PORT=3000
BACKEND_PORT=8000

# LiveKit — local profile (default)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_INTERNAL_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit Cloud — cloud profile (uncomment and set)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_INTERNAL_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

WORKER_API_SECRET=change-me-in-production

GROQ_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GOOGLE_API_KEY=
BEY_API_KEY=
BEY_AVATAR_ID=
TAVUS_API_KEY=
TAVUS_PERSONA_ID=
TAVUS_REPLICA_ID=

# Agent: set true only if Agent Observability is enabled in LiveKit Cloud project settings
# LIVEKIT_CLOUD_OBSERVABILITY=false
